# ══════════════════════════════════════════════════
# CRMF360 Backend — Variables de entorno (EJEMPLO)
# ══════════════════════════════════════════════════
# Copia este archivo como .env y configura los valores.

# ── Base de datos (PostgreSQL) ──
ConnectionStrings__pg="Host=localhost;Port=5433;Database=crmf360_db;Username=crmf360_user;Password=CAMBIAR_PASSWORD"

# ── JWT — IMPORTANTE: la key debe tener mínimo 32 caracteres ──
Jwt__Key=CAMBIAR_CLAVE_SECRETA_MIN_32_CARACTERES_AQUI!
Jwt__Issuer=CRMF360
Jwt__Audience=CRMF360-BackOffice
Jwt__ExpiresInMinutes=480
Jwt__RefreshExpireDays=7

# ── ASP.NET ─────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── CORS (Orígenes permitidos, separados por coma) ──
Cors__Origins=http://localhost:5173,http://localhost:3000
